/* ============================================================================
 *  HDDHealth Monitor - Win32 resource script
 *  ---------------------------------------------------------------------------
 *  100% Free and Open Source Software (FOSS).
 *
 *  Author  : Ari Soandri Putra
 *  Company : ARImetic Inc.
 *  Sponsor : https://github.com/sponsors/arisohandriputra/
 *  License : MIT
 *
 *  This script defines:
 *    - The application icons (IDI_APPICON, IDI_HDD)
 *    - The side-by-side application manifest (Common-Controls v6 + admin)
 *    - The standard VS_VERSION_INFO block embedded into the .exe
 * ============================================================================
 */

#include <windows.h>
#include "resource.h"

/* Application icons.  The same .ico file is reused for both the main
   application icon and the drive icon used in the tray / drive buttons. */
IDI_APPICON  ICON  "app.ico"
IDI_HDD      ICON  "app.ico"

/* Embed the application manifest (Common-Controls v6 + requireAdministrator). */
1 24 "app.manifest"

/* ----------------------------------------------------------------------------
 *  Version information block.
 *
 *  Windows Explorer's "Details" tab reads these values from the .exe.
 *  All fields are kept in sync with the author / sponsor metadata used
 *  elsewhere in the project.
 * ---------------------------------------------------------------------------- */
VS_VERSION_INFO VERSIONINFO
 FILEVERSION    1,1,0,0
 PRODUCTVERSION 1,1,0,0
 FILEFLAGSMASK  VS_FFI_FILEFLAGSMASK
 FILEFLAGS      0x0L
 FILEOS         VOS_NT_WINDOWS32
 FILETYPE       VFT_APP
 FILESUBTYPE    VFT2_UNKNOWN
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName",      "ARImetic Inc."
            VALUE "FileDescription",  "Low-Level HDD Health Monitor - Free Open Source"
            VALUE "FileVersion",      "1.1.0.0"
            VALUE "InternalName",     "HDD Health Monitor 1.1"
            VALUE "LegalCopyright",   "Copyright (c) 2026 Ari Soandri Putra. MIT License."
            VALUE "OriginalFilename", "HDDHealth.exe"
            VALUE "ProductName",      "HDDHealth 1.1"
            VALUE "ProductVersion",   "1.1.0.0"
            VALUE "Comments",         "100% Free Open Source Software. Author: Ari Soandri Putra (ARImetic Inc.). Sponsor: https://github.com/sponsors/arisohandriputra/"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x0409, 1200
    END
END
